{
  "expo": {
    "name": "HybridPilot",
    "slug": "HybridPilot",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/icon1.png",
    "scheme": "hybridpilot",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/cat-1.png",
      "resizeMode": "contain",
      "backgroundColor": "#191c1f"
    },
    "ios": {
      "bundleIdentifier": "com.hybridpilot.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.hybridpilot.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon1.png",
        "backgroundColor": "#F6EFDf"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/cat-1.png",
          "resizeMode": "contain",
          "backgroundColor": "#191c1f",
          "imageWidth": 200
        }
      ],
      [
        "expo-web-browser",
        {
          "experimentalLauncherActivity": false
        }
      ],
      "expo-camera",
      "expo-font",
      "expo-sqlite"
    ]
  }
}
