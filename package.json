{
  "name": "dribsnis",
  "version": "1.0.3",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "ios:release:device": "expo run:ios --configuration Release --device",
    "web": "expo start --web",
    "build:apk": "npx eas-cli build --platform android --profile preview",
    "build:aab": "npx eas-cli build --platform android --profile production",
    "build:ios": "npx eas-cli build --platform ios --profile production",
    "prebuild:ios": "expo prebuild -p ios",
    "prebuild:ios:clean": "expo prebuild -p ios --clean",
    "prebuild:android": "expo prebuild -p android",
    "build:apk:local": "cd android && gradlew assembleRelease -PreactNativeArchitectures=arm64-v8a",
    "build:aab:local": "cd android && gradlew bundleRelease -PreactNativeArchitectures=arm64-v8a",
    "build:apk:local:debug": "cd android && gradlew assembleDebug"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@reduxjs/toolkit": "^2.11.2",
    "@shopify/react-native-skia": "2.2.12",
    "@supabase/supabase-js": "^2.101.1",
    "axios": "^1.14.0",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "d3-zoom": "^3.0.0",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-camera": "~17.0.10",
    "expo-crypto": "~15.0.8",
    "expo-font": "~14.0.11",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "phosphor-react-native": "^3.0.4",
    "polished": "^4.3.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.2.0",
    "victory-native": "^41.20.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
